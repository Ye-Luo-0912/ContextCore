{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "ContextCore": "Debug"
    }
  },
  "Security": {
    "RequireApiKey": false
  },
  "Storage": {
    "Provider": "filesystem",
    "RootPath": "",
    "PostgresConnectionString": ""
  },
  "Compression": {
    "Provider": "mock"
  },
  "JobWorker": {
    "Enabled": true,
    "PollIntervalMilliseconds": 500
  },
  "ModelGateway": {
    "ApiProviders": [
      {
        "Name": "mock-api",
        "Provider": "mock",
        "Endpoint": "",
        "ApiKey": "",
        "Enabled": true
      },
      {
        "Name": "deepseek",
        "Provider": "deepseek",
        "Endpoint": "https://api.deepseek.com/v1",
        "ApiKey": "env:DEEPSEEK_API_KEY",
        "Enabled": false
      },
      {
        "Name": "pinai-openai",
        "Provider": "openai-compatible",
        "Endpoint": "https://us.pinai-cn.com/v1",
        "ApiKey": "env:PINAI_OPENAI_API_KEY",
        "Enabled": false,
        "Metadata": {
          "apiKeyEnv": "PINAI_OPENAI_API_KEY"
        }
      }
    ],
    "ModelProfiles": [
      {
        "Name": "mock",
        "ApiProviderName": "mock-api",
        "Model": "mock",
        "Category": "mock",
        "Capabilities": [ "chat", "compression", "fallback" ],
        "Roles": [ "Router", "GeneralCompression", "StrongReasoning", "Validator", "Fallback" ],
        "TaskKinds": [ "Summarize", "ExtractKeyPoints", "GenerateIndexHints", "Reduce", "Merge", "Validate", "Custom" ],
        "ThinkingModes": [ "fast", "balanced", "deep", "audit" ],
        "Metadata": {
          "priority": "1"
        }
      },
      {
        "Name": "deepseek-v4-flash",
        "ApiProviderName": "deepseek",
        "Model": "deepseek-v4-flash",
        "Category": "fast",
        "Capabilities": [ "chat", "compression", "json-response-format", "routing" ],
        "Enabled": false
      },
      {
        "Name": "deepseek-v4-pro",
        "ApiProviderName": "deepseek",
        "Model": "deepseek-v4-pro",
        "Category": "balanced",
        "Capabilities": [ "chat", "compression", "reasoning", "structured-json-by-prompt" ],
        "SupportsJsonResponseFormat": false,
        "Enabled": false
      },
      {
        "Name": "pinai-gpt-5.4",
        "ApiProviderName": "pinai-openai",
        "Model": "gpt-5.4",
        "Category": "deep",
        "Capabilities": [ "chat", "compression", "reasoning", "json-response-format" ],
        "Enabled": false
      },
      {
        "Name": "pinai-gpt-5.5",
        "ApiProviderName": "pinai-openai",
        "Model": "gpt-5.5",
        "Category": "audit",
        "Capabilities": [ "chat", "compression", "reasoning", "audit", "json-response-format", "validation" ],
        "Enabled": false
      }
    ],
    "Routes": [
      {
        "Role": "GeneralCompression",
        "TaskKind": "Summarize,ExtractKeyPoints,GenerateIndexHints,Reduce,Merge,Validate,Custom",
        "ThinkingMode": "fast,balanced,deep,audit",
        "PrimaryModelCategory": "mock",
        "FallbackModelName": "",
        "FallbackModelCategory": "",
        "RequiredCapabilities": [ "compression" ],
        "Priority": 100,
        "MaxRetryCount": 0,
        "EnableFallback": false
      },
      {
        "Role": "Fallback",
        "TaskKind": "",
        "ThinkingMode": "",
        "PrimaryModelCategory": "mock",
        "FallbackModelName": "",
        "FallbackModelCategory": "",
        "RequiredCapabilities": [ "compression" ],
        "Priority": 1,
        "MaxRetryCount": 0,
        "EnableFallback": false
      }
    ]
  }
}
