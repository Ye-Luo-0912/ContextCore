  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-ContextCore-Key",
        "description": "Header name only; secret values are never serialized."
      }
    },
    "schemas": {
      "FoundationApiResponseEnvelope": {
        "type": "object",
        "required": [
          "Success",
          "CapabilityId",
          "Status",
          "Recommendation",
          "Data",
          "Diagnostics",
          "GeneratedAt",
          "SchemaVersion"
        ],
        "properties": {
          "Success": {
            "type": "boolean"
          },
          "CapabilityId": {
            "type": "string"
          },
          "Status": {
            "type": "string"
          },
          "Recommendation": {
            "type": "string"
          },
          "Data": {},
          "Diagnostics": {
            "type": "object"
          },
          "GeneratedAt": {
            "type": "string",
            "format": "date-time"
          },
          "SchemaVersion": {
            "type": "string",
            "const": "foundation-api-envelope-v1"
          }
        }
      },
      "DegradedFoundationEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/FoundationApiResponseEnvelope"
          }
        ],
        "properties": {
          "Status": {
            "const": "Degraded"
          },
          "Recommendation": {
            "const": "RegenerateReport"
          },
          "Diagnostics": {
            "type": "object",
            "properties": {
              "MissingReportIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "FoundationStatusEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/FoundationApiResponseEnvelope"
          }
        ],
        "properties": {
          "Data": {
            "$ref": "#/components/schemas/FoundationServiceStatusResponse"
          }
        }
      },
      "FoundationReportNavigationEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/FoundationApiResponseEnvelope"
          }
        ],
        "properties": {
          "Data": {
            "$ref": "#/components/schemas/FoundationReportNavigationResponse"
          }
        }
      },
      "FoundationReportEntryEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/FoundationApiResponseEnvelope"
          }
        ],
        "properties": {
          "Data": {
            "$ref": "#/components/schemas/FoundationReportNavigationEntry"
          }
        }
      },
      "FoundationServiceStatusResponse": {
        "type": "object",
        "properties": {
          "Capabilities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CapabilityStatus"
            }
          },
          "FormalRetrievalAllowed": {
            "type": "boolean",
            "const": false
          },
          "RuntimeSwitchAllowed": {
            "type": "boolean",
            "const": false
          },
          "ReadyForRuntimeSwitch": {
            "type": "boolean",
            "const": false
          }
        }
      },
      "CapabilityStatus": {
        "type": "object",
        "required": [
          "CapabilityId",
          "DisplayName",
          "Category",
          "State",
          "Recommendation",
          "GatePassed",
          "UseForRuntime",
          "FormalRetrievalAllowed",
          "RuntimeSwitchAllowed",
          "ReadyForRuntimeSwitch",
          "PackingPolicyChanged",
          "PackageOutputChanged",
          "SourceReportPath",
          "AllowedModes",
          "ForbiddenModes",
          "BlockedReasons"
        ],
        "properties": {
          "CapabilityId": {
            "type": "string"
          },
          "DisplayName": {
            "type": "string"
          },
          "Category": {
            "type": "string"
          },
          "State": {
            "type": "string"
          },
          "Recommendation": {
            "type": "string"
          },
          "GatePassed": {
            "type": "string"
          },
          "UseForRuntime": {
            "type": "string"
          },
          "FormalRetrievalAllowed": {
            "type": "string"
          },
          "RuntimeSwitchAllowed": {
            "type": "string"
          },
          "ReadyForRuntimeSwitch": {
            "type": "string"
          },
          "PackingPolicyChanged": {
            "type": "string"
          },
          "PackageOutputChanged": {
            "type": "string"
          },
          "SourceReportPath": {
            "type": "string"
          },
          "AllowedModes": {
            "type": "string"
          },
          "ForbiddenModes": {
            "type": "string"
          },
          "BlockedReasons": {
            "type": "string"
          }
        }
      },
      "FoundationReportNavigationResponse": {
        "type": "object",
        "properties": {
          "Reports": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FoundationReportNavigationEntry"
            }
          },
          "MissingReportIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "FoundationReportNavigationEntry": {
        "type": "object",
        "required": [
          "ReportId",
          "CapabilityId",
          "RelativePath",
          "Exists",
          "GeneratedAt",
          "ContentType",
          "Summary",
          "SafeToExpose"
        ],
        "properties": {
          "ReportId": {
            "type": "string"
          },
          "CapabilityId": {
            "type": "string"
          },
          "RelativePath": {
            "type": "string"
          },
          "Exists": {
            "type": "string"
          },
          "GeneratedAt": {
            "type": "string"
          },
          "ContentType": {
            "type": "string"
          },
          "Summary": {
            "type": "string"
          },
          "SafeToExpose": {
            "type": "string"
          }
        }
      }
    }
  },
  "x-envelopeSchemaVersion": "foundation-api-envelope-v1",
  "x-forbiddenRuntimeActions": [
    "RuntimeSwitch",
    "FormalRetrieval",
    "FormalPackageWrite",
    "PackingPolicyMutation",
    "PackageOutputMutation",
    "NonAllowlistedScopeUse"
  ],
  "x-useForRuntime": false,
